# Resume Generation System - Environment Configuration
# Copy this file to .env and customize for your setup

# ============================================================================
# Agent Configuration
# ============================================================================

# Agent type (auto-detect, claude, gemini, openai, custom)
AGENT_TYPE=auto-detect

# Claude Code (if using)
# CLAUDE_CODE_SESSION=auto  # Set by Claude Code automatically

# Gemini CLI (if using)
# GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_AI_STUDIO=your_studio_key_here

# OpenAI GPT-4 (if using)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_ORGANIZATION=your_org_id_here

# ============================================================================
# MCP Server Configuration (for Claude Code and compatible agents)
# ============================================================================

# Resume Memory MCP Server
DATABASE_PATH=./resume-memory-mcp/data/memory.db
KNOWLEDGE_GRAPH_PATH=./resume-memory-mcp/data/knowledge-graph.json

# Semantic Search API (optional, improves similarity checking)
SEMANTIC_API_URL=http://127.0.0.1:8001
SEMANTIC_API_ENABLED=false  # Set to true if Python txtai API is running

# Resume Generator MCP Server
RESUME_OUTPUT_DIR=./generated-resumes

# ============================================================================
# Application Workflow Configuration
# ============================================================================

# Directory paths (relative to project root)
APPLICATION_TRACKING_DIR=./job-prep/applications
BASELINE_RESUME_PATH=./job-prep/applications/_resources/baseline-resume-data.json
PROFILE_SUMMARY_PATH=./job-prep/applications/_resources/profile-summary.md

# Similarity thresholds (0.0 to 1.0)
SIMILARITY_THRESHOLD_USE_EXISTING=0.95  # 95%+ similarity → recommend reuse
SIMILARITY_THRESHOLD_TAILOR=0.80        # 80-95% similarity → recommend tailor
# Below 80% → recommend create new

# Workflow options
AUTO_TRACK_APPLICATIONS=true  # Automatically track applications in database
VALIDATION_REQUIRED=true      # Require validation before PDF generation
SHOW_TOKEN_USAGE=true         # Display token usage and costs

# ============================================================================
# External Services (optional)
# ============================================================================

# LaTeX Resume API (used by resume-generator MCP)
# LATEX_API_URL=https://latexresu.me/api/generate  # Default

# txtai Semantic Search (Python FastAPI)
# Set SEMANTIC_API_ENABLED=true to use this
# Start with: cd resume-memory-mcp/semantic-search-api && python main.py

# ============================================================================
# Development & Debugging
# ============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Debug mode (shows detailed workflow steps)
DEBUG_MODE=false

# Dry run (don't actually save files, useful for testing)
DRY_RUN=false

# ============================================================================
# Performance Tuning
# ============================================================================

# Maximum applications to check for similarity
MAX_SIMILARITY_CHECKS=50  # Check last 50 applications

# Profile compression ratio target
PROFILE_COMPRESSION_TARGET=0.10  # Compress to 10% of original (~200 tokens from ~2000)

# PDF generation timeout (milliseconds)
PDF_GENERATION_TIMEOUT=30000  # 30 seconds

# ============================================================================
# Git Integration (optional)
# ============================================================================

# Auto-commit generated resumes
AUTO_COMMIT_RESUMES=false

# Git commit message template
# GIT_COMMIT_MESSAGE="Add resume for {company} - {role}"

# ============================================================================
# Notifications (optional, for future use)
# ============================================================================

# Email notifications when resume generated
# EMAIL_NOTIFICATIONS_ENABLED=false
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=your-email@example.com
# EMAIL_TO=your-email@example.com

# Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# Notes
# ============================================================================

# This file contains configuration for the resume generation system.
# Most settings have sensible defaults and don't need to be changed.
#
# Required settings:
#   - None (system works with defaults)
#
# Recommended settings:
#   - SEMANTIC_API_ENABLED=true (if you want best similarity matching)
#   - DATABASE_PATH (if you want to customize database location)
#
# Optional settings:
#   - All API keys (if using specific agents)
#   - Performance tuning (if experiencing issues)
#
# For more information, see:
#   - SETUP_FOR_DISTRIBUTION.md
#   - CUSTOMIZATION_GUIDE.md
#   - .agent-config/README.md
